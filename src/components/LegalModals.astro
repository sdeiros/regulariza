---
import { site } from '../config';
---

<dialog id="modal-termos" class="modal">
  <div class="modal-topo">
    <h2>Termos de Uso</h2>
    <button type="button" class="fechar" data-fecha-modal aria-label="Fechar">×</button>
  </div>
  <div class="modal-corpo">
